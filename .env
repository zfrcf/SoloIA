# Base de données MongoDB (optionnelle). Sans elle, SoloIA fonctionne quand
# même : localStorage reste la source de vérité locale, MongoDB ne fait que
# mirroiser les crédits/plan/conversations en tâche de fond quand disponible.
# Local : mongodb://localhost:27017/soloia
# Atlas (cloud, gratuit) : mongodb+srv://<user>:<motdepasse>@<cluster>.mongodb.net/soloia
MONGODB_URI=mongodb://localhost:27017/soloia
