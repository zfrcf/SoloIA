# SoloIA environment configuration
SOLOIA_APP_NAME=SoloIA
SOLOIA_ENV=development
SOLOIA_DATA_DIR=

# Optional AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json
FIREBASE_DATABASE_URL=

# Search settings
SEARCH_USER_AGENT=SoloIA/1.0

# SoloIA Pro / Termux bridge
TERMUX_BASE_URL=http://192.168.1.10:8765
TERMUX_TOKEN=soloia-dev-token
LLAMA_CPP_URL=http://127.0.0.1:8080
OLLAMA_URL=http://127.0.0.1:11434
